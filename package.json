{
  "name": "wayang-code",
  "displayName": "Wayang Code",
  "description": "Wayang agent for coding",
  "version": "0.1.0",
  "publisher": "KayysTech",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:wayangChat",
    "onCommand:wayang.sendQuery",
    "onCommand:wayang.analyzeFile",
    "onCommand:wayang.generateTests",
    "onCommand:wayang.explainCode",
    "onCommand:wayang.refactorCode",
    "onCommand:wayang.findAndFix",
    "onCommand:wayang.clearMemory",
    "onCommand:wayang.showMemory",
    "onCommand:wayang.configure",
    "onCommand:wayang.refreshTasks",
    "onCommand:wayang.cancelTask"
  ],
  "contributes": {
    "commands": [
      {
        "command": "wayang.sendQuery",
        "title": "Wayang Code: Send Query"
      },
      {
        "command": "wayang.analyzeFile",
        "title": "Wayang Code: Analyze File"
      },
      {
        "command": "wayang.generateTests",
        "title": "Wayang Code: Generate Tests"
      },
      {
        "command": "wayang.explainCode",
        "title": "Wayang Code: Explain Code"
      },
      {
        "command": "wayang.refactorCode",
        "title": "Wayang Code: Refactor Code"
      },
      {
        "command": "wayang.findAndFix",
        "title": "Wayang Code: Find & Fix Issues"
      },
      {
        "command": "wayang.clearMemory",
        "title": "Wayang Code: Clear Memory"
      },
      {
        "command": "wayang.showMemory",
        "title": "Wayang Code: Show Memory"
      },
      {
        "command": "wayang.configure",
        "title": "Wayang Code: Configure"
      },
      {
        "command": "wayang.refreshTasks",
        "title": "Wayang Code: Refresh Tasks"
      },
      {
        "command": "wayang.cancelTask",
        "title": "Wayang Code: Cancel Task"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wayang",
          "title": "Wayang",
          "icon": "media/wayang-icon.png"
        }
      ]
    },
    "views": {
      "wayang": [
        {
          "id": "wayangChat",
          "name": "Chat",
          "type": "webview",
          "initialContent": "Loading...",
          "visibility": "visible"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "wayangChat",
        "contents": "Welcome to Wayang Code Assistant!\n\n[Open Chat](command:wayang.openChat)"
      }
    ]
  },
  "main": "./dist/extension.js",
  "assets": [
    "media/*"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && npm run build:webview && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && npm run build:webview && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "build:webview": "esbuild src/scripts/client-script.js --bundle --outdir=dist/scripts --platform=browser",
    "build": "npm run build:webview && tsc -p ./"
  },
  "devDependencies": {
    "@babel/core": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.103.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.8",
    "eslint": "^9.32.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.3"
  }
}