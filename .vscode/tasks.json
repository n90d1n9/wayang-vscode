// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "dependsOn": [
        "watch:tsc",
        "watch:esbuild"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "never"
      }
    },
    {
      "label": "watch:esbuild",
      "type": "shell",
      "command": "pnpm watch:esbuild",
      "isBackground": true,
      "group": "build",
      "problemMatcher": {
        "owner": "typescript",
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+): (error|warning): (.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*watching.*",
          "endsPattern": ".*done.*"
        }
      },
      "presentation": {
        "group": "watch",
        "reveal": "never"
      }
    },
    {
      "label": "watch:tsc",
      "type": "shell",
      "command": "pnpm watch:tsc",
      "isBackground": true,
      "group": "build",
      "problemMatcher": "$tsc-watch",
      "presentation": {
        "group": "watch",
        "reveal": "never"
      }
    },
    {
      "label": "watch-tests",
      "type": "shell",
      "command": "pnpm watch-tests",
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "group": "build",
      "presentation": {
        "reveal": "never",
        "group": "watchers"
      }
    },
    {
      "label": "tasks: watch-tests",
      "dependsOn": [
        "watch",
        "watch-tests"
      ],
      "problemMatcher": []
    },
    {
      "type": "npm",
      "script": "watch",
      "group": "build",
      "problemMatcher": "$esbuild-watch",
      "isBackground": true,
      "label": "npm: watch"
    },
    {
      "type": "npm",
      "script": "build",
      "group": "build",
      "problemMatcher": "$esbuild",
      "label": "npm: build"
    }
  ]
}
